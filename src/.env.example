# ─── Veritabanı ─────────────────────────────────────────────────
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Kimlik Doğrulama ────────────────────────────────────────────
# iron-session şifreleme anahtarı (min 32 karakter)
# Üretmek için: openssl rand -hex 32
AUTH_SECRET=your-secret-key-min-32-characters-long-here

# ─── E-posta (Opsiyonel — Sprint 1) ─────────────────────────────
# Resend API anahtarı — parola sıfırlama e-postaları için
# Yoksa e-postalar konsola loglanır
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── GitHub (Opsiyonel — Sprint 4) ──────────────────────────────
# GitHub Personal Access Token — repo import için
# Yoksa rate limit 60 istek/saat (token ile 5000)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
